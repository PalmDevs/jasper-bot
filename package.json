{
  "name": "jasper-bot",
  "description": "Providing Discord assistance as well as occasional yelling.",
  "version": "1.0.0",
  "module": "dist/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run build && bun run .",
    "dev": "bun run --watch src/index.ts",
    "build": "bun run scripts/build.ts",
    "build:config": "bun run scripts/build-config.ts",
    "check": "biome check .",
    "fix": "biome check . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.5"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "erlpack",
    "esbuild",
    "protobufjs",
    "zlib-sync"
  ],
  "dependencies": {
    "@genkit-ai/googleai": "^1.21.0",
    "@sapphire/async-queue": "^1.5.5",
    "@sapphire/duration": "^1.2.0",
    "chalk-template": "^1.1.2",
    "decancer": "^3.3.3",
    "drizzle-orm": "^0.44.6",
    "fast-fuzzy": "^1.12.0",
    "fastest-levenshtein": "^1.0.16",
    "oceanic.js": "^1.12.0",
    "quick-lru": "^7.3.0"
  },
  "optionalDependencies": {
    "erlpack": "^0.1.4",
    "zlib-sync": "^0.1.10"
  }
}