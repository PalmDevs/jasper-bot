{
  "name": "jasper-bot",
  "description": "Providing Discord assistance as well as occasional yelling.",
  "version": "1.0.0",
  "module": "dist/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run build && bun run .",
    "dev": "bun run --watch src/index.ts",
    "build": "bun run scripts/build.ts",
    "build:config": "bun run scripts/build-config.ts",
    "check": "biome check .",
    "fix": "biome check . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "1.3.13",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@firebase/util",
    "erlpack",
    "esbuild",
    "protobufjs",
    "zlib-sync"
  ],
  "dependencies": {
    "@genkit-ai/google-genai": "^1.33.0",
    "@sapphire/async-queue": "^1.5.5",
    "@sapphire/duration": "^1.2.0",
    "chalk-template": "^1.1.2",
    "decancer": "^3.3.3",
    "drizzle-orm": "^0.45.2",
    "fast-fuzzy": "^1.12.0",
    "fastest-levenshtein": "^1.0.16",
    "oceanic.js": "^1.14.0",
    "quick-lru": "^7.3.0"
  }
}
